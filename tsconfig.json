{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "ES2021",
    "types": [
      "bun"
    ],
    "removeComments": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "moduleResolution": "bundler",
    "module": "ES2022",
    "lib": [
      "ESNext",
      "DOM",
      "ScriptHost"
    ],
    "declaration": true
  },
  "include": [
    "src/**/*"
  ]
}